{
  "name": "@mdaemon/html-editor-react",
  "version": "1.4.1",
  "description": "React wrapper for MDHTMLEditor",
  "homepage": "https://github.com/mdaemon-technologies/MDHTMLEditor-react",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdaemon-technologies/MDHTMLEditor-react.git"
  },
  "bugs": {
    "url": "https://github.com/mdaemon-technologies/MDHTMLEditor-react/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "dev": "vite build --watch --mode development",
    "demo": "vite serve --config vite.demo.config.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "html-editor",
    "wysiwyg",
    "react",
    "tiptap"
  ],
  "author": {
    "name": "MDaemon Technologies, Ltd.",
    "email": "jonathan.ehman@mdaemon.com",
    "url": "https://www.mdaemon.com"
  },
  "license": "LGPL-3.0-or-later",
  "peerDependencies": {
    "react": "^19.0.0 || ^18.0.0",
    "react-dom": "^19.0.0 || ^18.0.0"
  },
  "dependencies": {
    "@mdaemon/html-editor": "^1.6.0",
    "@tiptap/react": "^3.23.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@swc/core": "^1.11.0",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "allowScripts": {
    "@swc/core@1.15.24": true,
    "esbuild@0.27.7": true,
    "unrs-resolver@1.11.1": true
  }
}
