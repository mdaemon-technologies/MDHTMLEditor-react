{
  "name": "@mdaemon/html-editor-react",
  "version": "1.0.2",
  "description": "React wrapper for MDHTMLEditor",
  "homepage": "https://github.com/mdaemon-technologies/MDHTMLEditor-react",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdaemon-technologies/MDHTMLEditor-react.git"
  },
  "bugs": {
    "url": "https://github.com/mdaemon-technologies/MDHTMLEditor-react/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --mode production",
    "build:dev": "vite build --mode development",
    "dev": "vite build --watch --mode development",
    "demo": "vite serve --config vite.demo.config.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "html-editor",
    "wysiwyg",
    "react",
    "tiptap"
  ],
  "author": {
    "name": "MDaemon Technologies, Ltd.",
    "email": "jonathan.ehman@mdaemon.com",
    "url": "https://www.mdaemon.com"
  },
  "license": "LGPL-3.0-or-later",
  "peerDependencies": {
    "react": "^19.0.0 || ^18.0.0",
    "react-dom": "^19.0.0 || ^18.0.0"
  },
  "dependencies": {
    "@tiptap/react": "^3.19.0"
  },
  "devDependencies": {
    "@mdaemon/html-editor": "^1.0.8",
    "@swc/core": "^1.11.0",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
